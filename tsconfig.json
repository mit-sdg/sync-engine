{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "@sync-engine/engine": ["./engine/index.ts"],
      "@sync-engine/engine/*": ["./engine/*"],
      "@sync-engine/sdk": ["./sdk/index.ts"],
      "@sync-engine/sdk/*": ["./sdk/*"],
      "@sync-engine/runtime": ["./runtime/index.ts"],
      "@sync-engine/runtime/*": ["./runtime/*"],
      "@sync-engine/devtools": ["./devtools/index.ts"],
      "@sync-engine/devtools/*": ["./devtools/*"],
      "@sync-engine/utils": ["./utils/index.ts"],
      "@sync-engine/utils/*": ["./utils/*"]
    }
  },
  "include": ["engine", "runtime", "sdk", "devtools", "utils", "tests"]
}
