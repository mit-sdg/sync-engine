{
  "name": "sync-engine",
  "version": "0.1.0",
  "description": "TypeScript-first synchronization engine — compose independent concepts with when/where/then rules over an append-only action journal",
  "keywords": [
    "concept",
    "declarative",
    "engine",
    "journal",
    "reactive",
    "state-machine",
    "synchronization"
  ],
  "license": "MIT",
  "author": "Barish Namazov",
  "repository": {
    "type": "git",
    "url": "https://github.com/BarishNamazov/sync-engine"
  },
  "files": [
    "engine/",
    "sdk/",
    "runtime/",
    "utils/",
    "devtools/"
  ],
  "type": "module",
  "exports": {
    ".": "./engine/index.ts",
    "./engine": "./engine/index.ts",
    "./engine/*": "./engine/*",
    "./sdk": "./sdk/index.ts",
    "./sdk/*": "./sdk/*",
    "./runtime": "./runtime/index.ts",
    "./runtime/*": "./runtime/*",
    "./utils": "./utils/index.ts",
    "./utils/*": "./utils/*",
    "./devtools/graph": "./devtools/graph/index.ts",
    "./devtools/graph/*": "./devtools/graph/*"
  },
  "scripts": {
    "check": "vp check",
    "test": "LOG_LEVEL=error vp test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "0.2.2"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  }
}
