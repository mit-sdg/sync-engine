{
  "name": "sync-engine",
  "version": "0.1.0",
  "description": "Declarative synchronization engine — compose independent concepts with when/where/then rules, driven by an append-only action journal.",
  "keywords": [
    "concept",
    "declarative",
    "engine",
    "journal",
    "reactive",
    "state-machine",
    "synchronization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BarishNamazov/sync-engine"
  },
  "type": "module",
  "exports": {
    ".": "./engine/index.ts",
    "./engine": "./engine/index.ts",
    "./engine/*": "./engine/*",
    "./sdk": "./sdk/index.ts",
    "./sdk/*": "./sdk/*",
    "./infra": "./infra/index.ts",
    "./infra/*": "./infra/*",
    "./runtime": "./runtime/index.ts",
    "./runtime/*": "./runtime/*",
    "./transport": "./transport/index.ts",
    "./transport/*": "./transport/*",
    "./utils": "./utils/index.ts",
    "./utils/*": "./utils/*",
    "./devtools/graph": "./devtools/graph/index.ts",
    "./devtools/graph/*": "./devtools/graph/*"
  },
  "scripts": {
    "check": "vp check",
    "test": "LOG_LEVEL=error vp test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mongodb": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "mongodb-memory-server": "^11.2.0",
    "typescript": "^5.9.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "0.2.2"
  },
  "peerDependencies": {
    "mongodb": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "mongodb": {
      "optional": true
    }
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  }
}
