{
  "name": "@mit-sdg/sync-engine",
  "version": "0.3.0",
  "description": "A TypeScript library for composing independent application behaviors declaratively",
  "keywords": [
    "concept",
    "declarative",
    "engine",
    "log",
    "reaction",
    "state-machine"
  ],
  "homepage": "https://github.com/mit-sdg/sync-engine#readme",
  "bugs": "https://github.com/mit-sdg/sync-engine/issues",
  "license": "Apache-2.0",
  "author": "Barish Namazov and Eagon Meng",
  "repository": {
    "type": "git",
    "url": "https://github.com/mit-sdg/sync-engine"
  },
  "bin": {
    "sync-engine": "./dist/command/artifacts.js"
  },
  "files": [
    "dist/",
    "docs/",
    "examples/",
    "NOTICE"
  ],
  "type": "module",
  "exports": {
    "./advanced": {
      "types": "./dist/advanced/index.d.ts",
      "import": "./dist/advanced/index.js"
    },
    "./assembly": {
      "types": "./dist/assembly/index.d.ts",
      "import": "./dist/assembly/index.js"
    },
    "./boundary": {
      "types": "./dist/boundary/index.d.ts",
      "import": "./dist/boundary/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./language": {
      "types": "./dist/language/index.d.ts",
      "import": "./dist/language/index.js"
    },
    "./tooling": {
      "types": "./dist/tooling/index.d.ts",
      "import": "./dist/tooling/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "check": "bun scripts/check-architecture.ts && vp check",
    "declarations:check": "bun run build && bun scripts/declarations.ts check",
    "declarations:pin": "bun run build && bun scripts/declarations.ts pin",
    "example": "bun run build && bun scripts/examples.ts scenario readingCircle",
    "example:operations": "bun run build && bun scripts/examples.ts scenario operationsRoom",
    "example:operations:pin": "bun scripts/examples.ts pin operationsRoom",
    "example:pin": "bun scripts/examples.ts pin readingCircle",
    "examples:check": "bun scripts/examples.ts check",
    "goldens": "bun run examples:check && LOG_LEVEL=error bun scripts/examples.ts test && LOG_LEVEL=error vp test tests/internal/reads/render.test.ts tests/golden/stitch/integration.test.ts",
    "package:check": "bun run build && bun scripts/verify-package.ts",
    "prepack": "bun run build",
    "scenario": "bun run build && bun scripts/examples.ts scenario",
    "stitch:pin": "bun scripts/pin-stitch-spec.ts",
    "test": "LOG_LEVEL=error vp test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "0.2.2"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.14"
}
